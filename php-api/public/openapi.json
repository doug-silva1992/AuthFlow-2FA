{
    "openapi": "3.0.0",
    "info": {
        "title": "AuthFlow 2FA API",
        "description": "Documentacao da API AuthFlow 2FA",
        "version": "1.0.0"
    },
    "paths": {
        "/": {
            "servers": [
                {
                    "url": "http://localhost:8080",
                    "description": "Ambiente local"
                }
            ]
        },
        "/users/register": {
            "post": {
                "tags": [
                    "Cadastrar Usuários"
                ],
                "summary": "Endpoint para cadastrar usuários",
                "operationId": "abfca6891307128ecfb5ba14c8f4c4c6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "client_name": {
                                        "description": "Nome do Cliente",
                                        "type": "string"
                                    },
                                    "email": {
                                        "description": "Email do usuário para o qual o cadastro está sendo realizado",
                                        "type": "string"
                                    },
                                    "senha": {
                                        "description": "Senha do usuário para o qual o cadastro está sendo realizado",
                                        "type": "string"
                                    },
                                    "fk_IdentityProvider": {
                                        "description": "ID do provedor de identidade para o qual o cadastro está sendo realizado (opcional, se não for fornecido, será usado um valor padrão)",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Cadastro realizado com sucesso"
                    }
                }
            }
        },
        "/authenticator/request_key": {
            "get": {
                "tags": [
                    "Authenticator"
                ],
                "summary": "Endpoint para solicitar a chave do Microsoft Authenticator ou do Google Authenticator",
                "operationId": "afa5ff2df491a8bd28b6ad4a28de1134",
                "parameters": [
                    {
                        "name": "user_id",
                        "in": "query",
                        "description": "ID do usuário para o qual a chave do autenticador está sendo solicitada",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Chave do autenticador retornada com sucesso"
                    }
                }
            }
        },
        "/authenticator/verify_code": {
            "get": {
                "tags": [
                    "Authenticator"
                ],
                "summary": "Endpoint para verificar o código de autenticação fornecido pelo usuário",
                "operationId": "66b8111462449f83a611262822f6aef0",
                "parameters": [
                    {
                        "name": "code",
                        "in": "query",
                        "description": "Valida o código de autenticação fornecido pelo usuário",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Código verificado com sucesso"
                    },
                    "400": {
                        "description": "Código inválido ou usuário não registrado"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Cadastrar Usuários",
            "description": "Cadastrar Usuários"
        },
        {
            "name": "Authenticator",
            "description": "Autenticadores de dois fatores (2FA) como Microsoft Authenticator e Google Authenticator"
        }
    ]
}